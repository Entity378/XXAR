<wixsharp:WpfDialog
    x:Class="XXAR.Installer.Dialogs.XXARInstallDirDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:wixsharp="clr-namespace:WixSharp.UI.WPF;assembly=WixSharp.UI.WPF"
    DialogTitle="[ProductName] Setup"
    Background="#10123A">
    <wixsharp:WpfDialog.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/XXAR.Installer.Build;component/Themes/XXARPalette.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </wixsharp:WpfDialog.Resources>

    <Grid Background="{DynamicResource XXARWindowBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="*" />
            <RowDefinition Height="53" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#0A0B28"
                BorderBrush="{DynamicResource XXARAccentBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Destination Folder"
                               Foreground="{DynamicResource XXARTextPrimaryBrush}"
                               FontSize="13" FontWeight="SemiBold" />
                    <TextBlock Text="Click Next to install to the default folder or Change to choose another."
                               Foreground="{DynamicResource XXARTextSecondaryBrush}"
                               FontSize="11" Margin="0,2,0,0" />
                </StackPanel>
                <Image Grid.Column="1"
                       Source="/XXAR.Installer.Build;component/Assets/XXAR-Logo2-512.png"
                       Height="44" Stretch="Uniform"
                       VerticalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality" />
            </Grid>
        </Border>

        <StackPanel Grid.Row="1" Margin="20,24,20,10">
            <TextBlock Text="Install XXAR to:"
                       Foreground="{DynamicResource XXARTextSecondaryBrush}"
                       FontSize="12" Margin="0,0,0,8" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="InstallDirPath"
                         Text="{Binding InstallDirPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource XXARTextBox}" />
                <Button Grid.Column="1" Content="Change..."
                        Style="{StaticResource XXARSecondaryButton}"
                        Margin="8,0,0,0" Click="Change_Click" />
            </Grid>
        </StackPanel>

        <Border Grid.Row="2" Background="#080922"
                BorderBrush="{DynamicResource XXARBorderBrush}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                        VerticalAlignment="Center" Margin="0,0,20,0">
                <Button x:Name="GoPrev" Content="[WixUIBack]"
                        Style="{StaticResource XXARSecondaryButton}"
                        Click="GoPrev_Click" Margin="4,0" />
                <Button x:Name="GoNext" Content="[WixUINext]"
                        Style="{StaticResource XXARPrimaryButton}"
                        Click="GoNext_Click" Margin="4,0" />
                <Button x:Name="Cancel" Content="[WixUICancel]"
                        Style="{StaticResource XXARSecondaryButton}"
                        Click="Cancel_Click" Margin="12,0,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</wixsharp:WpfDialog>
